
[user]
    name = QSmally
    email = git@qsmally.org
    signingkey = 4F3BA282C00595CB

[init]
    defaultBranch = master

[core]
    excludesFile = ~/.gitignore

[status]
    submodulesummary = true

[commit]
    gpgSign = true

[tag]
    gpgSign = true

[pull]
    rebase = false

[alias]
    conflicts = "diff --name-only --diff-filter=U"
    graph = "log --oneline --graph"
    purge = "!bash -c 'git remote prune origin && \
        git branch -v | \
        grep \"\\[gone\\]\" | \
        awk \"{print \\$1}\" | \
        xargs git branch -D'"
    save = "stash save --include-untracked" # [message]
    update = "!bash -c 'git pull && git submodule update --init --recursive && git purge'"
